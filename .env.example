APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting over the Pusher protocol (Velq's edge speaks it). Velq injects
# PUSHER_APP_ID / PUSHER_APP_KEY / PUSHER_APP_SECRET (via /bindings) and the
# PUSHER_HOST / PUSHER_PORT / PUSHER_SCHEME (from the WS listener) at runtime.
BROADCAST_CONNECTION=pusher

# Files. Locally this is the local disk; on Velq, velq-init sets FILESYSTEM_DISK=s3
# and the AWS_* + AWS_ENDPOINT env so Storage::disk('s3') targets Velq R2.
FILESYSTEM_DISK=local

QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail over SMTP. On Velq, velq-init injects MAIL_HOST / MAIL_PORT pointing at
# the mailpit catcher; no auth is required.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="guestbook@velq.dev"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# WebSockets (Pusher protocol). On Velq these are injected at runtime: the
# APP_* via /bindings, the HOST/PORT/SCHEME from the WS listener. Left blank
# here so a local `php artisan serve` does not try to reach Pusher Cloud.
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=
PUSHER_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
